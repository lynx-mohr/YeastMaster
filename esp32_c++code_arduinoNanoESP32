void drawWifiIcon(int x, int y, bool isInBox) {
  if (WiFi.SSID() == "") return;
  bool connected = (WiFi.status() == WL_CONNECTED);
  bool blink = (millis() % 1000 < 500);

  if (isInBox) u8g2.setDrawColor(0);
  else u8g2.setDrawColor(1);

  if (connected || blink) {
    u8g2.drawBox(x, y + 1, 2, 2);
    if (connected) {
      u8g2.drawBox(x + 3, y - 1, 2, 4);
      u8g2.drawBox(x + 6, y - 3, 2, 6);
    }
  }
  u8g2.setDrawColor(1);
}

void syncWithCloud() {

  // ==========================================
  // --- NYTT: HÅRDVARULÅS FÖR AKTIV JÄSNING ---
  // ==========================================
  // Vi kollar om maskinen är i läge RUNNING eller POURING
  if (currentState == RUNNING || currentState == POURING) {
    Serial.println("❌ SYNK AVBRUTEN: Jäsning pågår!");

    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tf);
    u8g2.drawStr(5, 15, "SYNC BLOCKED:");
    u8g2.drawStr(5, 30, "FERMENTATION");
    u8g2.drawStr(5, 45, "IS ACTIVE!");
    u8g2.sendBuffer();

    delay(4000);  // Låt användaren hinna läsa varningen
    return;       // Avbryt och gå tillbaka till menyn utan att göra något mer
  }
  // ==========================================

  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_6x10_tf);
  u8g2.drawStr(5, 15, "SYNCING WITH...");
  u8g2.drawStr(5, 30, "SOULOF.BEER");
  u8g2.sendBuffer();

  // 1. Skapa en säker klient för HTTPS
  WiFiClientSecure client;
  client.setInsecure();  // Gör att vi slipper ladda upp certifikat-filer

  HTTPClient http;

  Serial.println("Ansluter till molnet för personlig synk...");

  // --- NYTT: BYGG DYNAMISK URL MED MAC-ADRESS ---
  String macStr = WiFi.macAddress();
  String dynamicUrl = "https://soulofbeer-live.onrender.com/api/device-sync/" + macStr;

  Serial.print("Hämtar data från: ");
  Serial.println(dynamicUrl);

  // 2. Påbörja anslutningen med den säkra klienten och den dynamiska URL:en
  if (http.begin(client, dynamicUrl.c_str())) {
    int httpCode = http.GET();

    if (httpCode == HTTP_CODE_OK) {

      // Öppna filen i det interna minnet (FFat) för skrivning
      File file = FFat.open("/yeastdata.json", "w");
      if (file) {

        // --- MAGIN: Streama datan direkt till filen istället för att krascha RAM-minnet! ---
        http.writeToStream(&file);
        file.close();

        Serial.println("SYNC LYCKADES!");

        // Bekräftelse på skärmen
        u8g2.clearBuffer();
        u8g2.drawStr(5, 25, "Yeast Library:");
        u8g2.drawStr(5, 40, "UPDATED!");
        u8g2.sendBuffer();

        delay(2000);

        u8g2.clearBuffer();
        u8g2.drawStr(5, 30, "REBOOTING...");
        u8g2.sendBuffer();

        delay(1000);
        ESP.restart();  // Starta om för att ladda den nya jäst-datan
      } else {
        Serial.println("Kunde inte skriva till FFat.");
        u8g2.drawStr(5, 45, "DISK ERROR");
        u8g2.sendBuffer();
      }
    } else {
      // Om t.ex. Render svarar med 404 eller 500
      Serial.print("Anslutningsfel, kod: ");
      Serial.println(httpCode);
      u8g2.clearBuffer();
      u8g2.drawStr(5, 25, "SYNC FAILED");
      u8g2.setCursor(5, 45);
      u8g2.print("ERROR: ");
      u8g2.print(httpCode);
      u8g2.sendBuffer();
    }
    http.end();
  } else {
    Serial.println("Kunde inte initiera anslutning.");
    u8g2.drawStr(5, 45, "CONN ERROR");
    u8g2.sendBuffer();
  }

  delay(3000);  // Låt meddelandet ligga kvar en stund innan vi går vidare
}


