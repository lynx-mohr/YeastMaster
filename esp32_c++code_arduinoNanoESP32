void runWiFiPortal() {
  WiFiManager wm;
  wm.setConfigPortalTimeout(120);
  wm.setConfigPortalBlocking(false);
  wm.setConnectTimeout(1);
  wm.setSaveConnect(false);

  // Callback när användaren sparar sina nya WiFi-uppgifter
  auto onSave = [&]() {
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x12_tf);
    u8g2.drawStr(10, 30, "WIFI SAVED!");
    u8g2.drawStr(10, 45, "REBOOTING...");
    u8g2.sendBuffer();

    Serial.println("!!! Nya WiFi-uppgifter sparade. Startar om...");
    delay(2000);
    ESP.restart();  // Startar om för att ansluta direkt
  };

  wm.setSaveConfigCallback(onSave);
  wm.startConfigPortal("YeastMaster_Setup");
  unsigned long startTime = millis();

  while (millis() - startTime < 120000) {
    wm.process();

    // --- RITA SKÄRMEN (Uppdateras 1 gång per sekund) ---
    static unsigned long lastUpdate = 0;
    if (millis() - lastUpdate > 1000) {
      lastUpdate = millis();
      int remaining = 120 - (int)((millis() - startTime) / 1000);
      if (remaining < 0) remaining = 0;

      u8g2.clearBuffer();

      // 1. TOPPRAD: Rubrik och Timer
      u8g2.setFont(u8g2_font_5x7_tf);
      u8g2.drawStr(0, 8, "WIFI SETUP");
      u8g2.setCursor(95, 8);
      u8g2.print(remaining / 60);
      u8g2.print(":");
      if ((remaining % 60) < 10) u8g2.print("0");
      u8g2.print(remaining % 60);

      // 2. STEG 1: Nätverk att ansluta till
      u8g2.drawStr(0, 22, "1. Connect to WiFi:");
      u8g2.setFont(u8g2_font_6x10_tf);  // Större text för SSID
      u8g2.drawStr(5, 34, "YeastMaster_Setup");

      // 3. STEG 2: Webbadress (IP) att surfa till
      u8g2.setFont(u8g2_font_5x7_tf);
      u8g2.drawStr(0, 48, "2. Go to browser:");
      u8g2.setFont(u8g2_font_6x10_tf);  // Större text för IP-adressen
      u8g2.drawStr(5, 59, "192.168.4.1");

      // 4. PROGRESS BAR: Längst ner på skärmen
      int barWidth = map(remaining, 0, 120, 0, 128);
      u8g2.drawBox(0, 62, barWidth, 2);

      u8g2.sendBuffer();
    }
    yield();
  }

  // Tiden gick ut utan sparade uppgifter
  wm.stopConfigPortal();
  WiFi.mode(WIFI_STA);
}


