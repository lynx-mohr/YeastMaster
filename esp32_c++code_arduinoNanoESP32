void performCloudSync() {
  if (WiFi.status() != WL_CONNECTED) {
    DEBUG_PRINTLN("-> Nätverk: WiFi offline. Kan inte synka.");
    return;
  }

  // Vi lägger krypteringen i ett eget litet skal för att säkra RAM-minnet
  {
    WiFiClientSecure *client = new WiFiClientSecure();
    client->setInsecure();
    HTTPClient http;

    http.setTimeout(5000); 

    if (http.begin(*client, serverUrl)) { 
      http.addHeader("Content-Type", "application/json");

      StaticJsonDocument<512> sendDoc; 
      
      sendDoc["device_id"] = WiFi.macAddress();
      sendDoc["temp"] = t1;
      sendDoc["air_temp"] = t2;
      sendDoc["token"] = myAuthToken;

      // Bara RUNNING och POURING behövs här!
      if (currentState == RUNNING || currentState == POURING) {
        float d = (float)(millis() - brewStartTime) / 86400000.0 * TIME_MULTIPLIER;
        float realDaysPassed = (float)(millis() - realBrewStartTime) / 86400000.0 * TIME_MULTIPLIER;
        
        const char* currentStrain = "Unknown";
        const char* currentProfile = "Unknown";
        float phaseDay = 0.0;
        
        // Plocka säkert fram data
        if (yeastData.containsKey("yeasts") && yeastIndex < yeastData["yeasts"].size()) {
           currentStrain = yeastData["yeasts"][yeastIndex]["s"] | "Unknown";
           currentProfile = yeastData["yeasts"][yeastIndex]["p"] | "Unknown";
           JsonArray steps = yeastData["yeasts"][yeastIndex]["steps"];

            if (isManualMode) {
              if (steps.size() > 0) {
                float lastStepStart = steps[steps.size() - 2][0].as<float>();
                phaseDay = d - lastStepStart;
              }
            } else if (steps.size() > 0) {
              float currentPhaseStartDay = 0.0;
              for (int i = 0; i < steps.size(); i++) {
                if (d <= steps[i][0].as<float>()) {
                  currentPhaseStartDay = (i > 0) ? steps[i - 1][0].as<float>() : 0.0;
                  break;
                }
              }
              phaseDay = d - currentPhaseStartDay;
            }
            if (phaseDay < 0.0) phaseDay = 0.0;
        }

        sendDoc["day"] = realDaysPassed;
        sendDoc["profile_day"] = d;
        sendDoc["phase_day"] = phaseDay;
        
        // Den här funktionen räknar redan ut Cold Crash och Manual helt perfekt!
        sendDoc["status"] = String(getStatus(d));

        sendDoc["action"] = coolerActive ? "COOLING" : (heaterActive ? "HEATING" : "IDLE");
        sendDoc["active_alert"] = activeAlertMsg;
        sendDoc["strain"] = currentStrain;
        sendDoc["profile"] = currentProfile;
        sendDoc["target_temp"] = isManualMode ? manualTargetTemp : getDisplayGoalTemp(d);
      }
      else {
        sendDoc["day"] = 0.0;
        sendDoc["phase_day"] = 0.0;
        sendDoc["status"] = "IDLE";
        sendDoc["action"] = "IDLE";
        sendDoc["strain"] = "-";
        sendDoc["profile"] = "-";
        sendDoc["target_temp"] = 0.0;
      }

      String jsonPayload;
      serializeJson(sendDoc, jsonPayload);
      http.addHeader("Connection", "close");

      int httpResponseCode = http.POST(jsonPayload);
      if (httpResponseCode > 0) {
        DEBUG_PRINTLN("-> Render Cloud: Status synkad direkt!");
      } else {
        DEBUG_PRINT("-> Render Cloud: FEL (");
        DEBUG_PRINT(httpResponseCode);
        DEBUG_PRINTLN(")");
      }
      
      http.end();
    } else {
      DEBUG_PRINTLN("-> Render Cloud: Kunde inte ansluta.");
    }

    delete client; 
  } 
}


void loop() {

yield();

// =======================================================
  // ---> DEN MAGISKA KÖN (SMART & SÄKER) <---
  // =======================================================
  if (cloudSyncRequested) {
    // Vi väntar tills vi BÅDE har internet OCH det har gått 10 sekunder sedan sist
    if (WiFi.status() == WL_CONNECTED && (millis() - lastCloudSyncTime > 10000)) {
      Serial.println("-> KÖN: Öppnar luckan och skickar till molnet!");
      performCloudSync();            
      cloudSyncRequested = false;    // Töm kön först NÄR vi faktiskt skickat!
      lastCloudSyncTime = millis();  
    }
  }
  

  // --- VÄCK LARM-DETEKTIVEN ---
  float currentProfileDay = (float)(millis() - brewStartTime) / 86400000.0 * TIME_MULTIPLIER;
  if (currentState == RUNNING) updateActionAlerts(currentProfileDay);

  // =======================================================
  // ---> NYTT: BLIXTSNABB SYNK VID LARM <---
  // =======================================================
  static String lastSentAlertMsg = "";
 if (activeAlertMsg != lastSentAlertMsg) {
  cloudSyncRequested = true;                 // Tyst larm-synk
  lastSentAlertMsg = activeAlertMsg;  // Kom ihåg vad vi just skickade
}

  // --- LARM-LJUD ---
  static unsigned long lastAlertSound = 0;
  if (activeAlertMsg != "" && !alertAcknowledged) {
    if (millis() - lastAlertSound > 10000) {  // Piper var 10:e sekund (10000 ms)
      triggerSound(5);                        // Ger ifrån sig ett uppmärksammande dubbel-pip
      lastAlertSound = millis();
    }
  }

  int clkState = digitalRead(ENCODER_CLK);

  static unsigned long lastMove = 0;  // Tidpunkt för förra hacket

  if (clkState != lastClkState && clkState == LOW) {
    unsigned long now = millis();

    // Om det går för fort (under 50ms mellan hacken) är det förmodligen brus!
    if (now - lastMove > 50) {
      lastMove = now;
      lastActivity = millis();

      if (screenIsOff) {
        u8g2.setPowerSave(0);
        screenIsOff = false;
      } else {
        triggerSound(4);
        bool clockwise = (digitalRead(ENCODER_DT) != clkState);

        if (currentState == MAIN_MENU) {
          mainMenuIndex = (mainMenuIndex + (clockwise ? 1 : -1) + 2) % 2;
        } else if (currentState == SETTINGS_MENU) {
          settingsCursor = (settingsCursor + (clockwise ? 1 : -1) + 8) % 8;
        } else if (currentState == SET_OFFSET) {
          tempOffset = constrain(tempOffset + (clockwise ? 0.1 : -0.1), -1.0, 1.0);
        } else if (currentState == SELECT_YEAST) {
          int uniqueCount = 0;
          String lastS = "";
          for (int i = 0; i < dynamicTotalYeasts; i++) {
            const char* s = yeastData["yeasts"][i]["s"];
            if (s && String(s) != lastS) {
              uniqueCount++;
              lastS = String(s);
            }
          }
          int totalOptions = uniqueCount > 0 ? uniqueCount + 1 : 1;
          yeastIndex = (yeastIndex + (clockwise ? 1 : -1) + totalOptions) % totalOptions;
        } else if (currentState == SELECT_PROFILE) {
          int pCount = 0;
          for (int i = 0; i < dynamicTotalYeasts; i++) {
            const char* s = yeastData["yeasts"][i]["s"];
            if (s && strcmp(s, selectedStrainName) == 0) pCount++;
          }
          if (pCount > 0) profileIndex = (profileIndex + (clockwise ? 1 : -1) + pCount) % pCount;
        } else if (currentState == RUNNING) {
          if (dashboardPage < 2) dashboardPage = (dashboardPage + (clockwise ? 1 : -1) + 3) % 3;
          else menuSelection = (menuSelection + (clockwise ? 1 : -1) + 6) % 6;
        } else if (currentState == CONFIRM_ACTION) {
          confirmYesNo = (confirmYesNo + 1) % 2;
        } else if (currentState == SET_MANUAL_TEMP) {
          if (useFahrenheit) {
            manualTargetTemp += (clockwise ? 0.555 : -0.555);
          } else {
            manualTargetTemp += (clockwise ? 0.5 : -0.5);
          }
        }  // Stänger SET_MANUAL_TEMP
      }    // Stänger ELSE (skärm vaken)
    }      // Stänger IF (now - lastMove > 50)
  }        // <--- DENNA SAKNADES! (Stänger if clkState != lastClkState)

  lastClkState = clkState;



  // --- KLICKA PÅ RATTEN ---
  static bool lastBtnState = HIGH;
  bool currentBtnState = digitalRead(ENCODER_SW);
  if (lastBtnState == HIGH && currentBtnState == LOW) {
    delay(50);  // Debounce
    if (digitalRead(ENCODER_SW) == LOW) {
      lastActivity = millis();  // Nollställ skärmsläckaren!

      if (screenIsOff) {
        // Om skärmen sover, väck den bara. Utför inget klick i menyerna.
        u8g2.setPowerSave(0);
        screenIsOff = false;
      } else {
        // Skärmen är vaken -> Utför klick-logiken som vanligt!

        // --- 1. KOLLA OM VI MÅSTE KVITTERA ETT LARM ---
        if (currentState == RUNNING && activeAlertMsg != "") {
          alertAcknowledged = true;
          activeAlertMsg = "";
          triggerSound(0);  // Spela en glad "Success"-ton som bekräftelse!
        }
        // --- 2. ANNARS VANLIG MENYHANTERING ---
        else {
          triggerSound(5);
          if (currentState == MAIN_MENU) {
            if (mainMenuIndex == 0) currentState = SELECT_YEAST;
            else {
              stateBeforeSettings = MAIN_MENU;
              currentState = SETTINGS_MENU;
            }
          } else if (currentState == SETTINGS_MENU) {
            switch (settingsCursor) {
              case 0:
                useFahrenheit = !useFahrenheit;
                saveSystemSettings();
                break;
              case 1:
                syncWithCloud();
                currentState = MAIN_MENU;
                break;
              case 2:
                if (screenSleepMin == 0) screenSleepMin = 5;
                else if (screenSleepMin == 5) screenSleepMin = 15;
                else if (screenSleepMin == 15) screenSleepMin = 30;
                else screenSleepMin = 0;
                saveSystemSettings();
                break;
              case 3: currentState = SET_OFFSET; break;
              case 4:
                soundEnabled = !soundEnabled;
                saveSystemSettings();
                break;  // <-- NY RAD
              case 5:
                u8g2.clearBuffer();
                u8g2.setCursor(0, 20);
                u8g2.println("Clearing WiFi...");
                u8g2.sendBuffer();
                delay(1500);
                {
                  WiFiManager wm;
                  wm.resetSettings();
                  ESP.restart();
                }
                break;
              case 6: break;  // Mac-adress, gör ingenting
              case 7:
                currentState = stateBeforeSettings;  // Gå tillbaka till där vi kom ifrån!
                settingsCursor = 0;
                if (currentState == RUNNING) {
                  dashboardPage = 2;  // Stanna på action-menyn
                  menuSelection = 5;  // <--- NYTT: Hoppa direkt ner till "<- Back" i Action-menyn!
                }
                break;
            }
          } else if (currentState == SET_OFFSET) {
            saveSystemSettings();
            currentState = SETTINGS_MENU;
          } else if (currentState == SELECT_YEAST) {
            if (dynamicTotalYeasts <= 0 || !yeastData.containsKey("yeasts") || yeastData["yeasts"][0]["s"] == nullptr) {
              syncWithCloud();
            } else {
              int uniqueCount = 0;
              String lastS = "";
              for (int i = 0; i < dynamicTotalYeasts; i++) {
                const char* s = yeastData["yeasts"][i]["s"];
                if (s && String(s) != lastS) {
                  uniqueCount++;
                  lastS = String(s);
                }
              }

              if (yeastIndex == uniqueCount) {
                currentState = MAIN_MENU;
                yeastIndex = 0;
              } else {
                int count = 0;
                lastS = "";
                const char* foundPtr = nullptr;
                for (int i = 0; i < dynamicTotalYeasts; i++) {
                  const char* s = yeastData["yeasts"][i]["s"];
                  if (s == nullptr) continue;
                  if (String(s) != lastS) {
                    if (count == yeastIndex) {
                      foundPtr = s;
                      break;
                    }
                    count++;
                    lastS = String(s);
                  }
                }
                if (foundPtr != nullptr) {
                  memset(selectedStrainName, 0, sizeof(selectedStrainName));
                  strncpy(selectedStrainName, foundPtr, sizeof(selectedStrainName) - 1);
                  profileIndex = 0;
                  currentState = SELECT_PROFILE;
                }
              }
            }
          } else if (currentState == SELECT_PROFILE) {
            int pMatch = 0;
            bool found = false;
            for (int i = 0; i < dynamicTotalYeasts; i++) {
              const char* jsonS = yeastData["yeasts"][i]["s"];
              if (jsonS && strcmp(jsonS, selectedStrainName) == 0) {
                if (pMatch == profileIndex) {
                  yeastIndex = i;
                  found = true;
                  break;
                }
                pMatch++;
              }
            }
            if (found) {
              brewStartTime = millis();
              realBrewStartTime = millis();
              fillLevel = 53;
              foamHeight = 0;
              currentState = POURING;
              saveBrewState();
             cloudSyncRequested = true;
            }
          } else if (currentState == RUNNING && dashboardPage == 2) {
            if (menuSelection == 4) {  // SETTINGS
              stateBeforeSettings = RUNNING;
              currentState = SETTINGS_MENU;
              settingsCursor = 0;
            } else if (menuSelection == 5) {  // BACK
              dashboardPage = 0;              // Gå tillbaka till damejeang-vyn
              menuSelection = 0;              // Nollställ markören till nästa gång
            } else {
              currentState = CONFIRM_ACTION;
              confirmYesNo = 0;
            }
          } else if (currentState == CONFIRM_ACTION) {
            if (confirmYesNo == 1) {
              if (menuSelection == 0) {
                JsonArray steps = yeastData["yeasts"][yeastIndex]["steps"];
                float primaryEnd = 0.0;
                for (int i = 0; i < steps.size(); i++) {
                  if (steps[i][0].as<float>() > 0.1) {
                    primaryEnd = steps[i][0].as<float>();
                    break;
                  }
                }
                brewStartTime = millis() - (unsigned long)((primaryEnd + 0.01) * 86400000.0 / TIME_MULTIPLIER);
                isManualMode = false;
                currentState = RUNNING;
                dashboardPage = 0;
                saveBrewState();
                cloudSyncRequested = true;
                lastCloudSyncTime = millis();
                
              } else if (menuSelection == 1) {
                JsonArray steps = yeastData["yeasts"][yeastIndex]["steps"];
                bool foundCrash = false;
                for (int i = 0; i < steps.size(); i++) {
                  if (steps[i][1].as<float>() <= 6.5) {
                    float prevEnd = (i > 0) ? steps[i - 1][0].as<float>() : 0.0;
                    brewStartTime = millis() - (unsigned long)((prevEnd + 0.01) * 86400000.0 / TIME_MULTIPLIER);
                    foundCrash = true;
                    break;
                  }
                }
                if (!foundCrash) {
                  isManualMode = true;
                  manualTargetTemp = 4.0;
                } else {
                  isManualMode = false;
                }
                currentState = RUNNING;
                dashboardPage = 0;
                saveBrewState();
                cloudSyncRequested = true;
                lastCloudSyncTime = millis();
               
              } else if (menuSelection == 2) {
                currentState = SET_MANUAL_TEMP;
              } else if (menuSelection == 3) {
                // 1. Direkt feedback på skärmen!
                u8g2.clearBuffer();
                u8g2.setFont(u8g2_font_6x12_tf);
                u8g2.drawStr(20, 30, "Resetting...");
                u8g2.sendBuffer();

                // 2. Stäng av hårdvaran och nollställ minnet
                sendNexaMessage(false, coolerRecipient);
                coolerActive = false;
                sendNexaMessage(false, heaterRecipient);
                heaterActive = false;
                clearSavedState();
                brewStartTime = 0;
                yeastIndex = 0;
                profileIndex = 0;
                isManualMode = false;
                fillLevel = 53;
                foamHeight = 0;

                // --- FIX 1: LÅS UPP KOMPRESSORN ---
                isCompressorResting = false;
                lastCoolerStopTime = 0;

                // 3. Skicka uppdatering till molnet (Detta sker nu tyst i bakgrunden!)
               cloudSyncRequested = true;

                // 4. Ge användaren 1 sekund att se "Resetting..." innan vi hoppar tillbaka
                delay(1000);

                // 5. Hoppa tillbaka till huvudmenyn
                currentState = MAIN_MENU;
                mainMenuIndex = 0;
                triggerSound(0);
              }
            } else {
              currentState = RUNNING;
              dashboardPage = 0;
            }
          } else if (currentState == SET_MANUAL_TEMP) {
            isManualMode = true;
            currentState = RUNNING;
            dashboardPage = 0;
            saveBrewState();
            cloudSyncRequested = true;
            lastCloudSyncTime = millis();
          }
        }
      }  // Slut på else (skärmen var vaken)

      while (digitalRead(ENCODER_SW) == LOW)
        ;
    }
  }
  lastBtnState = currentBtnState;

  // =======================================================
  // --- DEN LAGGFRI TEMPERATUR-LÄSAREN ---
  // =======================================================
  static unsigned long lastTempRequest = 0;
  static bool isWaitingForTemp = false;

  // STEG 1: Ropa på sensorn var 5:e sekund ("Börja mäta!")
  if (millis() - lastMeasure > 5000 && !isWaitingForTemp && currentState != POURING) {

    // ---> NYTT: Rå OneWire-signal som rundar parasit-buggen! <---
    oneWire->reset();
    oneWire->skip();          // Prata med alla sensorer samtidigt
    oneWire->write(0x44, 0);  // 0x44 = Starta mätning. 0 = INGEN tvångs-delay!

    lastTempRequest = millis();  // Starta äggklockan
    isWaitingForTemp = true;     // Kom ihåg att vi väntar på svar
  }

  // STEG 2: Hämta svaret 800 millisekunder senare (När sensorn garanterat tänkt klart)
  if (isWaitingForTemp && (millis() - lastTempRequest > 800)) {

    float rawT1 = sensors->getTempCByIndex(0);
    float rawT2 = sensors->getTempCByIndex(1);

    // ==========================================
    // --- DATATVÄTT & AUTOMATISK VOODOO-FIX ---
    // ==========================================
    static int errorCount = 0;

    if (rawT1 <= -50.0 || rawT1 == 85.0) {
      errorCount++;
      Serial.println("Sensorglapp upptäckt! Döljer spiken...");

      // Om den misslyckas 4 gånger i rad (20 sekunder), kör vi omstarten!
      if (errorCount > 3) {
        t1 = -127.0;
        Serial.println("-> Sensorn har hängt sig. Utför Voodoo-återställning!");

        // 1. Stryp bussen fysiskt
       pinMode(ONEWIRE_ARDUINO, OUTPUT);
       digitalWrite(ONEWIRE_ARDUINO, LOW);
        delay(500);

        // 2. Släpp upp bussen och låt strömmen stabilisera sig
        pinMode(ONEWIRE_ARDUINO, INPUT_PULLUP);
        delay(200);

        // 3. Radera de gamla objekten i processorns minne
        delete sensors;
        delete oneWire;

        // 4. Skapa helt nya objekt (Samma sak som när du flashar ny kod!)
       oneWire = new OneWire(ONEWIRE_RAW);
        sensors = new DallasTemperature(oneWire);
        sensors->begin();
        sensors->setWaitForConversion(true);

        Serial.println("-> Sensor omstartad i farten!");
        errorCount = 0;  // Nollställ räknaren
      }
    } else {
      errorCount = 0;
      t1 = rawT1 + tempOffset;

      DEBUG_PRINTLN("SUCCESS! Temp är: ");
      DEBUG_PRINT(t1);
    
    }
    // ==========================================

    if (rawT2 > -50.0 && rawT2 != 85.0) {
      t2 = rawT2;
    }

    lastMeasure = millis();    // Återställ 5-sekunders-timern
    isWaitingForTemp = false;  // Vi är klara, sluta vänta!
  }

// =======================================================
      // --- DIAGNOSTISK TERMOSTAT-LOGIK ---
      // =======================================================
      
      // 1. ABSOLUT SÄKERHETSSPÄRR: Har vi en giltig temperatur?
      // (-127.0 betyder att sensorn inte vaknat än, eller är trasig)
      if (t1 <= -100.0) {
        
        // Nödstopp / Vänteläge: Stäng av allt tills vi vet hur varmt ölet är!
        if (heaterActive) { sendNexaMessage(false, heaterRecipient); heaterActive = false; }
        if (coolerActive) { sendNexaMessage(false, coolerRecipient); coolerActive = false; }
        
      } 
      // 2. DEN RIKTIGA TERMOSTATEN (Körs BARA om vi har en bra temperatur)
      else if (currentState == RUNNING) {
        
        float d = (float)(millis() - brewStartTime) / 86400000.0 * TIME_MULTIPLIER;
        
        // Beräkna målen
        float rampGoal = isManualMode ? manualTargetTemp : getTargetTemp(d);
        float finalGoal = isManualMode ? manualTargetTemp : getDisplayGoalTemp(d);

        // --- SMARTA TAK OCH GOLV (Free Rise & Free Fall) ---
        bool isHeatingPhase = (!isManualMode && finalGoal > rampGoal);
        bool isCoolingPhase = (!isManualMode && finalGoal < rampGoal);
        
        float coolTarget = isHeatingPhase ? finalGoal : rampGoal;
        float heatTarget = isCoolingPhase ? finalGoal : rampGoal;

        // KOMPRESSORSKYDD-CHECK
        if (isCompressorResting && (millis() - lastCoolerStopTime >= COMPRESSOR_DELAY)) {
          isCompressorResting = false;
        }

        // KYL-LOGIK (Slår den i taket?)
        if (t1 > coolTarget + 0.5) {
          if (!coolerActive && !isCompressorResting) {
            if (heaterActive) { 
              sendNexaMessage(false, heaterRecipient); 
              heaterActive = false; 
            }
            sendNexaMessage(true, coolerRecipient);
            coolerActive = true;
            triggerSound(1);
            
            Serial.println("-> TERMOSTAT: Ändrad till COOLING!");
            cloudSyncRequested = true;
            lastCloudSyncTime = millis(); 
          }
        } 
        else if (t1 <= coolTarget) {
          if (coolerActive) {
            sendNexaMessage(false, coolerRecipient);
            coolerActive = false;
            triggerSound(2);
            lastCoolerStopTime = millis();
            isCompressorResting = true;
            
            Serial.println("-> TERMOSTAT: Ändrad till IDLE (Kylning avslutad)");
            cloudSyncRequested = true; 
            lastCloudSyncTime = millis(); 
          }
        }

        // VÄRME-LOGIK (Faller den genom golvet?)
        if (t1 < heatTarget - 0.5) {
          if (!heaterActive && !coolerActive) {
            sendNexaMessage(true, heaterRecipient);
            heaterActive = true;
            
            Serial.println("-> TERMOSTAT: Ändrad till HEATING!");
            cloudSyncRequested = true;
            lastCloudSyncTime = millis(); 
          }
        } 
        else if (t1 >= heatTarget) {
          if (heaterActive) {
            sendNexaMessage(false, heaterRecipient);
            heaterActive = false;
            
            Serial.println("-> TERMOSTAT: Ändrad till IDLE (Värme avslutad)");
            cloudSyncRequested = true;
            lastCloudSyncTime = millis(); 
          }
        }
      
    } else if (t1 <= -100.0) {
      // Nödstopp om sensorn dör helt
      if (heaterActive) { sendNexaMessage(false, heaterRecipient); heaterActive = false; }
      if (coolerActive) { sendNexaMessage(false, coolerRecipient); coolerActive = false; }
    }

  static unsigned long lastDraw = 0;
  if (millis() - lastDraw > 50) {
    lastDraw = millis();
    u8g2.clearBuffer();
    u8g2.setDrawColor(1);  // Tvinga vit färg!

    // ---------------------------------------------------------
    // --- 🚨 TOTAL ÖVERKÖRNING: FULLSCREEN LARM 🚨 ---
    // ---------------------------------------------------------
    if (currentState == RUNNING && activeAlertMsg != "") {
      if (millis() % 2000 < 1000) {
        // Stor, tjock font för själva larmtexten
        u8g2.setFont(u8g2_font_9x15B_tf);
        int tW = u8g2.getStrWidth(activeAlertMsg.c_str());
        u8g2.setCursor(64 - (tW / 2), 32);
        u8g2.print(activeAlertMsg);

        // Liten undertitel i botten
        u8g2.setFont(u8g2_font_5x7_tf);
        int subW = u8g2.getStrWidth("CLICK TO DISMISS");
        u8g2.drawStr(64 - (subW / 2), 52, "CLICK TO DISMISS");
      }

      // Skicka larm-skärmen till displayen och stanna här!
      u8g2.sendBuffer();
      return;
    }

    // --- NYTT: OM SKÄRMEN SOVER, RITA BARA BUBBLOR! ---
    if (screenIsOff) {
      handleScreensaverAnimation();
      u8g2.sendBuffer();
      return;  // AVBRYT! Gå inte vidare och rita menyerna under.
    }

    float daysPassed = (float)(millis() - brewStartTime) / 86400000.0 * TIME_MULTIPLIER;
    float realDaysPassed = (float)(millis() - realBrewStartTime) / 86400000.0 * TIME_MULTIPLIER;

    if (currentState == MAIN_MENU) {
      drawMainMenu();
    } else if (currentState == SETTINGS_MENU) {
      drawSettingsMenu();
    } else if (currentState == SELECT_YEAST) {
      drawYeastMenu();
    } else if (currentState == SELECT_PROFILE) {
      u8g2.setFont(u8g2_font_6x12_tf);
      u8g2.drawStr(4, 9, "2. Select Profile");
      u8g2.drawLine(0, 11, 128, 11);
      int pM = 0;
      int dC = 0;
      for (int i = 0; i < dynamicTotalYeasts; i++) {
        const char* s = yeastData["yeasts"][i]["s"];
        if (s && strcmp(s, selectedStrainName) == 0) {
          if (pM >= profileIndex - 1 && dC < 4) {
            int yP = 24 + (dC * 13);
            const char* pN = yeastData["yeasts"][i]["p"];
            if (pM == profileIndex) {
              u8g2.setDrawColor(1);
              u8g2.drawBox(0, yP - 10, 128, 13);
              u8g2.setDrawColor(0);
              u8g2.drawStr(4, yP, pN ? pN : "Std");
              u8g2.setDrawColor(1);
            } else u8g2.drawStr(4, yP, pN ? pN : "Std");
            dC++;
          }
          pM++;
        }
      }
    } else if (currentState == POURING) {
      u8g2.drawLine(10, 20, 10, 42);
      u8g2.drawLine(34, 20, 34, 42);
      u8g2.drawLine(10, 20, 34, 20);
      u8g2.drawCircle(22, 42, 12, U8G2_DRAW_LOWER_LEFT | U8G2_DRAW_LOWER_RIGHT);
      u8g2.drawLine(20, 54, 24, 54);
      u8g2.drawLine(22, 54, 22, 57);
      u8g2.drawLine(16, 58, 28, 58);

      if (fillLevel > 20) fillLevel -= 0.4;
      static int sF = 0;
      if (sF++ % 4 == 0 && fillLevel > 21) triggerSound(3);

      if (foamHeight < 12.0) foamHeight += 0.2;

      for (int y = 53; y >= (int)fillLevel; y--) {
        int xS, xE;
        if (y <= 42) {
          xS = 11;
          xE = 33;
        } else {
          float dy = y - 42;
          float w = sqrt(max(0.0f, 144.0f - dy * dy));
          xS = 22 - (int)w + 1;
          xE = 22 + (int)w - 1;
        }
        for (int x = xS; x <= xE; x++) {
          if ((x + y) % 2 == 0) u8g2.drawPixel(x, y);
        }
      }

      if (foamHeight > 1 && fillLevel < 50) {
        int sy = (int)fillLevel;
        float fH = foamHeight;
        u8g2.drawDisc(13, sy - (int)(fH / 3), (int)(fH / 3));
        u8g2.drawDisc(19, sy - (int)(fH / 2), (int)(fH / 2));
        u8g2.drawDisc(25, sy - (int)(fH / 1.8), (int)(fH / 1.8));
        u8g2.drawDisc(31, sy - (int)(fH / 3), (int)(fH / 3));
      }

      u8g2.setFont(u8g2_font_6x12_tf);
      u8g2.drawBox(53, 0, 75, 14);
      u8g2.setDrawColor(0);

      const char* yN = yeastData["yeasts"][yeastIndex]["s"];
      const char* safeYN = yN ? yN : "Sync";
      u8g2.drawStr(53 + (75 - u8g2.getStrWidth(safeYN)) / 2, 11, safeYN);
      u8g2.setDrawColor(1);

      drawWifiIcon(2, 5, false);

      u8g2.setFont(u8g2_font_5x7_tf);
      u8g2.drawStr(53, 26, "PROFILE:");
      u8g2.setFont(u8g2_font_6x10_tf);

      const char* pN = yeastData["yeasts"][yeastIndex]["p"];
      u8g2.drawStr(53, 37, pN ? pN : "Std");

      u8g2.setFont(u8g2_font_5x7_tf);
      u8g2.drawStr(53, 48, "INOCULATING:");
      u8g2.setFont(u8g2_font_6x10_tf);
      u8g2.drawStr(53, 59, safeYN);

      for (int i = 0; i < 8; i++) {
        if (b[i].y > fillLevel) {
          u8g2.drawPixel((int)(22 + sin(b[i].y * 0.4) * 2), (int)b[i].y);
        }
        b[i].y -= b[i].spd;
        if (b[i].y < 21) resetBubble(i, false);
      }

      if (millis() - brewStartTime > 7000) {
        currentState = RUNNING;
        dashboardPage = 0;
      }
    } else if (currentState == CONFIRM_ACTION) {
      u8g2.setFont(u8g2_font_6x12_tf);
      u8g2.drawStr(10, 20, "Are you sure?");
      u8g2.setFont(u8g2_font_5x7_tf);
      const char* ns[] = { "Induce Clean", "Induce Crash", "Manual Temp", "Fresh Start" };
      u8g2.drawStr(10, 31, ns[menuSelection]);
      u8g2.setFont(u8g2_font_6x12_tf);
      u8g2.drawStr(30, 50, "NO");
      u8g2.drawStr(80, 50, "YES");
      u8g2.drawFrame(confirmYesNo == 0 ? 25 : 75, 38, 35, 16);
    } else if (currentState == RUNNING) {
      if (dashboardPage == 0) {
        drawWifiIcon(2, 5, false);
        u8g2.setFont(u8g2_font_6x12_tf);
        u8g2.drawCircle(30, 29, 19);
        u8g2.drawBox(26, 5, 9, 6);
        u8g2.drawLine(24, 5, 36, 5);

        // --- FIX: LARM ELLER CENTRERAD TEMP ---
        u8g2.setFont(u8g2_font_6x10_tf);

        // Om larm är aktivt, blinka varannan sekund mellan Larm och Temperatur!
        if (activeAlertMsg != "" && (millis() % 2000 < 1000)) {
          int tW = u8g2.getStrWidth(activeAlertMsg.c_str());
          u8g2.setCursor(30 - (tW / 2), 33);
          u8g2.print(activeAlertMsg);
        } else {
          String tStr = (t1 <= -100.0) ? "---" : (useFahrenheit ? String((t1 * 9.0 / 5.0) + 32.0, 1) + "F" : String(t1, 1) + "C");
          int tW = u8g2.getStrWidth(tStr.c_str());
          u8g2.setCursor(30 - (tW / 2), 33);
          u8g2.print(tStr);
        }
        u8g2.setFont(u8g2_font_6x12_tf);
        // ------------------------------------------------------------

        u8g2.drawBox(53, 0, 75, 14);
        u8g2.setDrawColor(0);
        const char* sN = yeastData["yeasts"][yeastIndex]["s"];
        u8g2.drawStr(56, 11, sN ? sN : "Brew");
        u8g2.setDrawColor(1);
        u8g2.setFont(u8g2_font_5x7_tf);
        const char* pN = yeastData["yeasts"][yeastIndex]["p"];
        u8g2.drawStr(126 - u8g2.getStrWidth(pN ? pN : "Std"), 25, pN ? pN : "Std");
        bool blk = (millis() % 1000 < 500);
        const char* st = coolerActive ? "COOLING" : (heaterActive ? "HEATING" : "IDLE");
        u8g2.drawStr(126 - u8g2.getStrWidth(st), 36, st);
        if ((coolerActive || heaterActive) && blk) {
          int ax = 126 - u8g2.getStrWidth(st) - 10;
          if (coolerActive) u8g2.drawTriangle(ax, 30, ax + 6, 30, ax + 3, 36);
          else u8g2.drawTriangle(ax, 36, ax + 6, 36, ax + 3, 30);
        }

        u8g2.setCursor(56, 47);
        u8g2.print("Air: ");
        printTempWithUnit(t2);

        for (int i = 0; i < 8; i++) {
          b[i].y -= b[i].spd;
          if (b[i].y < 12) resetBubble(i, true);
          u8g2.drawPixel((int)(30 + sin(b[i].y * 0.4) * 3), (int)b[i].y);
        }
     
} else if (dashboardPage == 1) {
        u8g2.setFont(u8g2_font_6x12_tf);
        u8g2.drawStr(4, 12, "FERM. DATA");
        u8g2.drawLine(0, 15, 128, 15);
        u8g2.setCursor(4, 32);
        u8g2.print("Day:  ");
        u8g2.print(realDaysPassed, 1);
        u8g2.setCursor(4, 47);
        u8g2.print("Goal: ");
        printTempWithUnit(isManualMode ? manualTargetTemp : getDisplayGoalTemp(daysPassed));
      } else {
        u8g2.setFont(u8g2_font_6x12_tf);
        u8g2.drawStr(4, 12, "ACTION MENU");
        u8g2.drawLine(0, 15, 128, 15);

        // Uppdaterad lista med 6 alternativ
        const char* m[] = { "Induce Clean", "Induce C Crash", "Manual Temp", "Fresh Start", "Settings", "<- Back" };

        // Vi räknar ut scroll-offset så att vi ser 4 rader åt gången
        int off = 0;
        if (menuSelection >= 4) off = menuSelection - 3;

        for (int i = 0; i < 4; i++) {
          int idx = i + off;
          if (idx > 5) break;  // Stoppa vid sista elementet (index 5)

          if (menuSelection == idx) {
            u8g2.setDrawColor(1);
            u8g2.drawBox(0, 16 + (i * 12), 128, 12);
            u8g2.setDrawColor(0);
          }
          u8g2.drawStr(4, 25 + (i * 12), m[idx]);
          u8g2.setDrawColor(1);
        }
      }
      if (dashboardPage != 2) {
        u8g2.drawLine(0, 51, 128, 51);
        u8g2.setFont(u8g2_font_6x10_tf);
        u8g2.setCursor(4, 61);
        u8g2.print("Status: ");

        if (activeAlertMsg != "") {
          u8g2.print("ACTION REQUIRED");  // Ändrar status-texten till en varning!
        } else {
          u8g2.print(getStatus(daysPassed));
        }
      }
    } else if (currentState == SET_MANUAL_TEMP) {
      u8g2.setFont(u8g2_font_6x12_tf);
      u8g2.drawStr(10, 20, "Set Manual Temp:");
      u8g2.setCursor(40, 45);
      printTempWithUnit(manualTargetTemp);
    }
    // --- NYTT: RITA SKÄRMEN FÖR ATT JUSTERA OFFSET ---
    else if (currentState == SET_OFFSET) {
      u8g2.setFont(u8g2_font_6x12_tf);
      u8g2.drawStr(10, 20, "Set Beer Offset:");
      u8g2.setCursor(40, 45);
      if (tempOffset > 0) u8g2.print("+");
      u8g2.print(tempOffset, 1);
      u8g2.print(" C");
    }

    u8g2.sendBuffer();
  }

  // --- SCREEN SAVER KONTROLL ---
  if (screenSleepMin > 0) {
    unsigned long timeout = screenSleepMin * 840000UL;
    if (millis() - lastActivity > timeout && !screenIsOff) {
      // Aktivera skärmsläckar-läget (men stäng INTE av strömmen till skärmen!)
      screenIsOff = true;
    }
  }


  // --- WIFI STATUS-LYSSNARE ---
  static bool wasConnected = false;
  bool isConnected = (WiFi.status() == WL_CONNECTED);
  if (isConnected && !wasConnected) {
    triggerSound(6);
    Serial.println("-> WiFi anslutet!");
  }
  wasConnected = isConnected;

  static unsigned long lastWiFiReconnect = 0;
  if (!isConnected && (millis() - lastWiFiReconnect > 30000)) {
    Serial.println("-> Offline. Försöker återansluta till WiFi...");
    WiFi.disconnect();
    WiFi.reconnect();
    lastWiFiReconnect = millis();
  }

  // --- KONTINUERLIG SPARNING och sändning ---
  static unsigned long lastPeriodicTask = 0;
  if (millis() - lastPeriodicTask > 840000) {
    lastPeriodicTask = millis();

    if (currentState == RUNNING || currentState == POURING) {
      saveBrewState();
    }

// Kalla på motorn tyst!
cloudSyncRequested = true;
}


}  // <--- Slut på void loop()


// --- FILSYSTEM & JSON ---
bool loadDataFromFS() {
  File file = FFat.open("/yeastdata.json", "r");
  if (!file) {
    deserializeJson(yeastData, "{\"yeasts\":[{\"n\":\"SYNC ERROR\",\"s\":\"Sync\"}]}");
    dynamicTotalYeasts = 1;
    return false;
  }
  
  DeserializationError error = deserializeJson(yeastData, file);
  if (error) {
    DEBUG_PRINT("-> JSON LÄSFEL: ");
    DEBUG_PRINTLN(error.c_str()); // Om hinken är för liten kommer det stå "NoMemory" här!
    file.close();
    return false;
  }
  
  dynamicTotalYeasts = yeastData["yeasts"].size();
  file.close();
  return true;
}

