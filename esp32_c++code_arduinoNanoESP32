void saveBrewState() {
  if (dynamicTotalYeasts < 2 && String(selectedStrainName) == "Sync") {
    Serial.println("-> Skippar sparande: Ingen riktig data laddad än.");
    return;
  }

  preferences.begin("brewmaster", false);
  float days = (float)(millis() - brewStartTime) / 86400000.0 * TIME_MULTIPLIER;
  bool isDone = (strcmp(getStatus(days), "FINISHED") == 0);
  bool shouldResume = (currentState == RUNNING || currentState == POURING) && !isDone;

  preferences.putBool("running", shouldResume);
  preferences.putInt("yeast", yeastIndex);
  preferences.putInt("profile", profileIndex);
  preferences.putBool("manual", isManualMode);
  preferences.putFloat("manTemp", manualTargetTemp);

  unsigned long elapsed = millis() - brewStartTime;
  unsigned long realElapsed = millis() - realBrewStartTime;
  preferences.putULong("elapsed", elapsed);
  preferences.putULong("realElapsed", realElapsed);
  preferences.end();

  //if (shouldResume) Serial.println("-> State saved to Flash");
  // else if (isDone) Serial.println("-> Batch finished: Not saving resume-state");
}

void clearSavedState() {
  preferences.begin("brewmaster", false);
  preferences.clear(); // <--- RENSAR BORT ALLT GAMMALT SKRÄP!
  preferences.putBool("running", false);
  preferences.end();
  Serial.println("-> Persistent state cleared completely!");
}

void loadBrewState() {
  preferences.begin("brewmaster", true);
  bool wasRunning = preferences.getBool("running", false);

  if (wasRunning) {
    yeastIndex = preferences.getInt("yeast", 0);
    profileIndex = preferences.getInt("profile", 0);
    isManualMode = preferences.getBool("manual", false);
    manualTargetTemp = preferences.getFloat("manTemp", 18.0);

    unsigned long savedElapsed = preferences.getULong("elapsed", 0);
    unsigned long savedRealElapsed = preferences.getULong("realElapsed", savedElapsed);
    brewStartTime = millis() - savedElapsed;
    realBrewStartTime = millis() - savedRealElapsed;  // <--- NY RAD

    currentState = RUNNING;
    dashboardPage = 0;
    Serial.println("-> RECOVERED: Resuming fermentation!");
  }
  preferences.end();
}

