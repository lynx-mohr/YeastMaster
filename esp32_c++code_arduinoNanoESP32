  for (int i = 0; i <= 16; i += 2) {
    u8g2.drawLine(63, 22, 63 + i, 22 - i);
    u8g2.drawLine(64, 22, 64 + i, 22 - i);  // +1 pixel tjocklek
    u8g2.sendBuffer();
    delay(animSpeed);
  }
  for (int i = 0; i <= 34; i += 2) {
    u8g2.drawLine(80, 6, 80, 6 + i);
    u8g2.drawLine(81, 6, 81, 6 + i);  // +1 pixel tjocklek
    u8g2.sendBuffer();
    delay(animSpeed);
  }

  delay(100);  // Kort spänningspaus innan sista strecket!

  // *** FAS 3: THE ALGIZ RUNE (Mittlinjen upp genom klykan) ***
  for (int i = 0; i <= 34; i += 2) {
    u8g2.drawLine(64, 40, 64, 40 - i);
    u8g2.drawLine(65, 40, 65, 40 - i);  // Behåller 2px tjocklek här med
    u8g2.sendBuffer();
    delay(animSpeed);
  }

  delay(1000);  // Låt den episka run-symbolen vila lite

  // *** FAS 4: THE BRAND REVEAL ***
  u8g2.setFont(u8g2_font_8x13B_tf);
  u8g2.drawStr(20, 56, "YEASTMASTER");
  u8g2.sendBuffer();
  delay(800);

  // *** FAS 5: SYSTEM VERSION ***
  u8g2.setFont(u8g2_font_5x7_tf);
  u8g2.drawStr(54, 64, "v2.1");
  u8g2.sendBuffer();
  delay(1200);

  // *** FAS 6: THE GRAND EXIT (Fade Out) ***
  for (int v = 255; v >= 0; v -= 10) {
    u8g2.setContrast(v);
    delay(10);
  }

  // Cleanup
  u8g2.clearBuffer();
  u8g2.sendBuffer();
  u8g2.setContrast(255);
  u8g2.setPowerSave(0);
}

void handleScreensaverAnimation() {
  int spawnInterval = 2000;  // Standard: Mycket lugnt (t.ex. när maskinen är Idle)
  float bubbleSpeed = 1.0;

  // Om vi brygger, öka bubbeltakten!
  if (currentState == RUNNING) {
    spawnInterval = 800;
    bubbleSpeed = 0.7;
  }

  // 1. SKAPA NYA BUBBLOR
  if (millis() - lastSSBubbleSpawn > spawnInterval) {
    for (int i = 0; i < MAX_SS_BUBBLES; i++) {
      if (!screensaverBubbles[i].active) {
        screensaverBubbles[i].x = random(5, 123);  // Slumpa horisontellt
        screensaverBubbles[i].y = 64;              // Starta i botten
        screensaverBubbles[i].speed = (random(15, 35) / 10.0) * bubbleSpeed;

        // BESTÄM STORLEKEN HÄR, EN GÅNG FÖR ALLA!
        screensaverBubbles[i].radius = random(1, 3);  // Får värdet 1 eller 2

        screensaverBubbles[i].active = true;
        lastSSBubbleSpawn = millis();
        break;
      }
    }
  }

  // 2. FLYTTA OCH RITA BUBBLOR
  for (int i = 0; i < MAX_SS_BUBBLES; i++) {
    if (screensaverBubbles[i].active) {
      screensaverBubbles[i].y -= screensaverBubbles[i].speed;  // Flytta uppåt

      // Rita bubblan med dess fasta radie istället för att slumpa varje frame
      u8g2.drawCircle(screensaverBubbles[i].x, screensaverBubbles[i].y, screensaverBubbles[i].radius);

      // Om bubblan lämnar toppen, gör den inaktiv
      if (screensaverBubbles[i].y < -5) {
        screensaverBubbles[i].active = false;
      }
    }
  }
}