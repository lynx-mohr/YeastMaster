float getDisplayGoalTemp(float days) {
  if (isManualMode) return manualTargetTemp;
  if (!yeastData.containsKey("yeasts")) return 20.0;

  JsonArray steps = yeastData["yeasts"][yeastIndex]["steps"];
  if (steps.isNull() || steps.size() == 0) return 20.0;

  for (int i = 0; i < steps.size(); i++) {
    if (days <= steps[i][0].as<float>()) {
      return steps[i][1].as<float>();
    }
  }
  return steps[steps.size() - 1][1].as<float>();
}

// --- ÅTERSTÄLLD TERMOSTAT-FUNKTION (GLIDANDE RAMP) ---
// --- UPPDATERAD: KÖR BARA RAMP UPPÅT, DROPPAR DIREKT NERÅT ---
// --- ÅTERSTÄLLD TERMOSTAT-FUNKTION (GLIDANDE RAMP) ---
float getTargetTemp(float days) {
  if (isManualMode) return manualTargetTemp;
  if (!yeastData.containsKey("yeasts")) return 20.0;

  JsonArray steps = yeastData["yeasts"][yeastIndex]["steps"];
  if (steps.isNull() || steps.size() < 2) return 20.0;  // FIX: Måste klara profiler med bara 2 steg

  if (days <= steps[0][0].as<float>()) return steps[0][1].as<float>();

  for (int i = 1; i < steps.size(); i++) {
    if (days <= steps[i][0].as<float>()) {
      float dStart = steps[i - 1][0].as<float>();
      float dEnd = steps[i][0].as<float>();
      float tStart = steps[i - 1][1].as<float>();
      float tEnd = steps[i][1].as<float>();

      // ==========================================
      // --- FIX: FÖRHINDRA "DIVIDE BY ZERO" CRASH ---
      // ==========================================
      if (dEnd - dStart == 0.0) {
        return tEnd;  // Punkterna ligger på samma sekund, hoppa direkt till nya tempen!
      }

      // Nu rampar vi mjuka övergångar oavsett om vi värmer eller kyler!
      return tStart + (tEnd - tStart) * ((days - dStart) / (dEnd - dStart));
    }
  }
  return steps[steps.size() - 1][1].as<float>();
}

// --- UPPDATERAD getStatus (Dag 0-säker) ---
const char* getStatus(float days) {
  if (isManualMode) {
    if (manualTargetTemp <= 6.5) return "COLD CRASH";
    return "MANUAL";
  }

  if (!yeastData.containsKey("yeasts")) return "READY TO SYNC";

  JsonArray steps = yeastData["yeasts"][yeastIndex]["steps"];
  if (steps.isNull() || steps.size() == 0) return "NO PROFILE";

  for (int i = 0; i < steps.size(); i++) {
    if (days <= steps[i][0].as<float>()) {
      float goalTemp = steps[i][1].as<float>();

      if (goalTemp <= 6.5) return "COLD CRASH";

      // --- FIX 2: KOLLA PRIMARY FÖRST ---
      bool isPrimary = false;
      if (i == 0) isPrimary = true;
      else if (i == 1 && steps[0][0].as<float>() < 0.1) isPrimary = true;

      if (isPrimary) return "PRIMARY";  // Även om temperaturen inte är nere på 20 än!

      // Är det INTE Primary, kolla om vi rampar
      if (i > 0 && t1 > -100.0) {
        if (abs(t1 - goalTemp) > 0.5) return "RAMPING";
      }

  if (steps[i].size() > 2) {
        const char* phaseName = steps[i][2].as<const char*>();
        if (phaseName != nullptr) return phaseName;
      }
      return "CLEANING UP";
    }
  }
  return "FINISHED";
}

