void printTempWithUnit(float tempC) {
  if (tempC <= -100.0) {
    u8g2.print("---");
  } else {
    if (useFahrenheit) {
      u8g2.print((tempC * 9.0 / 5.0) + 32.0, 1);
      u8g2.print("F");
    } else {
      u8g2.print(tempC, 1);
      u8g2.print("C");
    }
  }
}

