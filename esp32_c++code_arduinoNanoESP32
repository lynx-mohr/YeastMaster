void updateActionAlerts(float d) {
  if (!yeastData.containsKey("yeasts")) return;

  // --- SÄKERHETSSPÄRR 1: Kolla så vi inte letar utanför listan ---
  JsonArray yeasts = yeastData["yeasts"].as<JsonArray>();
  if (yeastIndex < 0 || yeastIndex >= yeasts.size()) return;

  // --- SÄKERHETSSPÄRR 2: Kolla så profilen faktiskt är giltig ---
  JsonObject profile = yeasts[yeastIndex].as<JsonObject>();
  if (profile.isNull()) return;

  float dryHopD = -1.0;
  float removeHopD = -1.0; // <-- NYTT: Variabel för borttagning av humle
  float rackD = -1.0;

  if (profile.containsKey("dryHopDay") && !profile["dryHopDay"].isNull()) {
    dryHopD = profile["dryHopDay"].as<float>();
  }
  // --- NYTT: Hämta removeHopDay från JSON-objektet ---
  if (profile.containsKey("removeHopDay") && !profile["removeHopDay"].isNull()) {
    removeHopD = profile["removeHopDay"].as<float>();
  }
  if (profile.containsKey("rackDumpDay") && !profile["rackDumpDay"].isNull()) {
    rackD = profile["rackDumpDay"].as<float>();
  }

  activeAlertMsg = "";

  // Larm-prioritering i kronologisk ordning
  if (rackD >= 0 && d >= rackD && d < (rackD + 1.0)) {
    if (!alertAcknowledged) activeAlertMsg = "DUMP YEAST!";
  } 
  // --- NYTT: Aktivera larmet när jäsningen når removeHopDay ---
  else if (removeHopD >= 0 && d >= removeHopD && d < (removeHopD + 1.0)) {
    if (!alertAcknowledged) activeAlertMsg = "REMOVE HOPS"; // Matchar frontend exakt!
  } 
  else if (dryHopD >= 0 && d >= dryHopD && d < (dryHopD + 1.0)) {
    if (!alertAcknowledged) activeAlertMsg = "DRY HOP!";
  } 
  else {
    // Om vi är mellan två larmfönster (t.ex. efter Dry Hop men före Remove Hops),
    // nollställer vi hänglåset så att nästa larm kan triggas igång!
    alertAcknowledged = false;
  }
}

